DATABASE_URL=sqlite:///jobcli.db      # or postgresql://user:pass@host/dbname
K8S_NAMESPACE=default                 # Kubernetes namespace for job pods
DOCKER_IMAGE=byteff2-service:latest   # Docker image for MD runner pods
CLUSTER_NUM_NODES=16                  # number of GPU nodes in the cluster
CLUSTER_GPUS_PER_NODE=8               # GPUs per node
SCHEDULER_POLL_INTERVAL=5             # seconds between scheduler polls
