#######################################################################
# Example Environment File
# !!! DO NOT PUT REAL SECRETS HERE. !!!
#######################################################################

# =============================================================================
# Storage backend selector
# Supported values: S3 | MINIO  (default: S3)
# =============================================================================
JOB_STORAGE_TYPE=S3

# =============================================================================
# S3 backend (used when JOB_STORAGE_TYPE=S3)
# =============================================================================
S3_ENDPOINT_URL=            # e.g. https://s3.amazonaws.com
S3_ACCESS_KEY=              # required
S3_SECRET_KEY=              # required
S3_BUCKET_NAME=             # optional, falls back to default bucket name

# =============================================================================
# MinIO backend (used when JOB_STORAGE_TYPE=MINIO)
# =============================================================================
MINIO_ENDPOINT=             # e.g. minio.example.com:9000
MINIO_ACCESS_KEY=           # required
MINIO_SECRET_KEY=           # required
MINIO_BUCKET=               # optional, falls back to default bucket name
MINIO_SECURE=false          # set to "true" to use TLS (HTTPS)

# =============================================================================
# run_md_job.py runtime settings
# =============================================================================
WORKSPACE_DIR=/app/workspace          # working root directory (default: /app/workspace)
PROGRESS_UPDATE_INTERVAL=3600         # background progress poll interval in seconds (default: 3600)
DEBUG_TOTAL_STEPS=                    # optional: override NPT/NVT/NEMD steps for quick testing (unset = use defaults)
